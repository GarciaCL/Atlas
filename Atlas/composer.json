{
    "name": "atlas/knowledge-operating-system",
    "description": "Atlas: The Knowledge Operating System Framework.",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Atlas\\": "app/",
            "Atlas\\WordPress\\": "wordpress/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}